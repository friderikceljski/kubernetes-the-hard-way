{
  "name": "Kubernetes Hard Way - Jumpbox",
  "image": "debian:trixie",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers"
      ]
    }
  },
  "postCreateCommand": "apt-get update && apt-get -y install wget curl vim openssl git",
  "mounts": [
    "source=${localEnv:HOME}/.kube,target=/root/.kube,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind"
  ],
  "forwardPorts": [6443, 8080],
  "remoteUser": "root"
}